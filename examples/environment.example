# Listener
PROXY_HOST=0.0.0.0
PROXY_PORT=3456
PROXY_API_KEY=replace-with-a-long-random-proxy-key

# vLLM upstream
# Proxy preserves the incoming model name exactly; configure vLLM --served-model-name to match Claude Code.
VLLM_BASE_URL=http://vllm:8001
VLLM_API_KEY=vllm

# Thinking mode is translated to vLLM chat_template_kwargs.enable_thinking
DEFAULT_ENABLE_THINKING=true

# Sampling defaults: only used when the incoming legal field is absent or invalid
DEFAULT_MAX_TOKENS=8192

# One internal recovery at most
MAX_RECOVERY_ATTEMPTS=1
RECOVERY_TEMPERATURE_MAX=0.45
RECOVERY_MAX_TOKENS=4096

# Ornith loop recovery. Default auto mode discovers network tools from current tools[].
RECOVERY_NETWORK_TEMPERATURE_MAX=0.30
RECOVERY_NETWORK_MAX_TOKENS=1024
RECOVERY_NETWORK_TOOL_MODE=auto

# Optional exact MCP overrides. First available configured name is forced.
RECOVERY_MCP_SEARCH_TOOL_PRIORITY=
RECOVERY_MCP_FETCH_TOOL_PRIORITY=

# Exact built-in／gateway names. Empty values disable those exact-name fallbacks.
RECOVERY_WEB_SEARCH_TOOL_NAMES=WebSearch
RECOVERY_WEB_FETCH_TOOL_NAMES=WebFetch

# Heartbeat and timeouts
HEARTBEAT_INTERVAL_MS=10000
UPSTREAM_IDLE_TIMEOUT_MS=180000
SEMANTIC_STALL_TIMEOUT_MS=300000
TOTAL_GENERATION_TIMEOUT_MS=1800000
RECOVERY_TIMEOUT_MS=900000
SHUTDOWN_GRACE_MS=300000

# Per-process and per-request limits
MAX_ACTIVE_REQUESTS=2000
MAX_REQUEST_BODY_BYTES=8388608
MAX_RESPONSE_BUFFER_BYTES=33554432
MAX_TOTAL_BUFFERED_BYTES=2147483648
MAX_THINKING_BYTES=4194304
MAX_TOOL_ARGUMENT_BYTES=8388608
MAX_CONTENT_BLOCKS=256
MAX_TOOL_CALLS=128

# Loop detector
LOOP_MIN_PATTERN_SIZE=24
LOOP_MAX_PATTERN_SIZE=2048
LOOP_MIN_COUNT=2
LOOP_REASONING_CHAR_LIMIT=24000
LOOP_SCAN_INTERVAL_CHARS=64

# Logs never include prompt, thinking, tool arguments, tool results, or API keys
LOG_LEVEL=info
